{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(git checkout *)",
      "Bash(git push *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git switch *)",
      "Bash(jj commit *)",
      "Bash(jj commit)",
      "Bash(jj new *)",
      "Bash(jj new)",
      "Bash(jj squash *)",
      "Bash(jj squash)",
      "Bash(jj split *)",
      "Bash(jj split)",
      "Bash(env *)",
      "Bash(env)",
      "Bash(export -p)",
      "Bash(export)",
      "Bash(history *)",
      "Bash(history)",
      "Bash(printenv *)",
      "Bash(printenv)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(set *)",
      "Bash(set)",
      "Bash(su *)",
      "Bash(sudo *)"
    ]
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  }
}
